#!/usr/bin/env bash
# Spanning wallpaper helper: updates the Omarchy background symlink and
# applies the image across all monitors. Two modes:
#   - With pre-split tile sidecar: issue hyprpaper IPC directly (fast path).
#   - Without: run rwpspread -b hyprpaper (does the split inline).
#
# Commands:
#   wallpaper <path>                   Set spanning wallpaper from file.
#   wallpaper --tiles <sidecar> <path> Apply pre-split tiles (fast IPC path).
#   wallpaper --refresh                Reapply the current background.
#   wallpaper --status                 Print cache/monitor diagnostics.
#   wallpaper                          Print the current wallpaper path.
set -euo pipefail

LINK="$HOME/.config/omarchy/current/background"
WATCHER_SKIP="$HOME/.config/omarchy/current/.wallpaper-skip"
TILES_SIDECAR=""

usage() {
  cat <<USAGE
Usage: wallpaper <path>                       Set spanning wallpaper from file.
       wallpaper --tiles <sidecar> <path>     Apply pre-split tiles listed in <sidecar>.
       wallpaper --refresh                    Reapply the current background (no symlink change).
       wallpaper --status                      Print monitor + cache diagnostics.
       wallpaper                              Print the current wallpaper path.

<sidecar> is a text file with one absolute tile path per line; tile filenames
must be of the form rwps_<MONITOR>_<HASH>.jpg (content-addressed by sha256).
USAGE
}

# --- --status: diagnostic dump (no side effects) ---
print_status() {
  echo "=== Monitors ==="
  hyprctl monitors 2>/dev/null | grep -E '^Monitor|description' || echo "  hyprctl unavailable"
  echo
  echo "=== Current background ==="
  if [[ -L "$LINK" ]]; then
    local img
    img="$(readlink -f "$LINK" 2>/dev/null || true)"
    echo "  link: $LINK -> $img"
    [[ -n "$img" && -f "$img" ]] && file "$img" | sed 's/^/  /' || echo "  (target missing)"
  else
    echo "  no background symlink at $LINK"
  fi
  echo
  echo "=== hyprpaper ==="
  local hp_pid
  hp_pid="$(pgrep -x hyprpaper 2>/dev/null || true)"
  if [[ -n "$hp_pid" ]]; then
    echo "  running (PID $hp_pid)"
    grep -q 'ipc = true' "$HOME/.config/hypr/hyprpaper.conf" 2>/dev/null \
      && echo "  ipc = true" || echo "  WARNING: ipc not enabled in hyprpaper.conf"
  else
    echo "  NOT running"
  fi
  echo
  echo "=== rwpspread ==="
  command -v rwpspread >/dev/null 2>&1 && echo "  $(rwpspread --version 2>&1 || echo 'installed')" || echo "  NOT installed"
  echo
  echo "=== omarchy-random-wallpaper cache ==="
  local cache="$HOME/.cache/omarchy-random-wallpaper"
  if [[ -d "$cache" ]]; then
    local slots=0 tiles=0 sidecars=0 broken=0 orphaned=0
    # Count with bash globs (no subshell exit on no-match with nullglob).
    shopt -s nullglob
    for f in "$cache"/slot-*.jpg "$cache"/slot-*.png "$cache"/slot-*.webp; do
      [[ -f "$f" ]] && slots=$((slots+1))
    done
    for f in "$cache"/tiles/*.jpg; do
      [[ -f "$f" ]] && tiles=$((tiles+1))
    done
    for f in "$cache"/.*.tiles; do
      [[ -f "$f" ]] && sidecars=$((sidecars+1))
    done
    shopt -u nullglob
    echo "  slots: $slots"
    echo "  tiles: $tiles"
    echo "  sidecars: $sidecars"
    echo "  .head: $(cat "$cache/.head" 2>/dev/null || echo '?')"
    echo "  disk: $(du -sh "$cache" 2>/dev/null | cut -f1)"
    # Check for broken sidecars
    for sc in "$cache"/.*.tiles; do
      [[ -f "$sc" ]] || continue
      while IFS= read -r tile || [[ -n "$tile" ]]; do
        [[ -n "$tile" ]] || continue
        [[ -f "$tile" ]] || { broken=$((broken+1)); break; }
      done <"$sc" 2>/dev/null
    done
    [[ "$broken" -gt 0 ]] && echo "  WARNING: $broken broken sidecar(s) (tiles missing)" || true
    # Check for orphaned tiles
    local ref tmp
    tmp=$(mktemp)
    for sc in "$cache"/.*.tiles; do
      [[ -f "$sc" ]] || continue
      cat "$sc" >>"$tmp" 2>/dev/null
    done
    for tile in "$cache"/tiles/*.jpg; do
      [[ -f "$tile" ]] || continue
      grep -qF "$tile" "$tmp" 2>/dev/null || orphaned=$((orphaned+1))
    done
    rm -f "$tmp"
    [[ "$orphaned" -gt 0 ]] && echo "  WARNING: $orphaned orphaned tile(s) (not referenced)" || true
  else
    echo "  no cache directory"
  fi
  echo
  echo "=== wallpaper-pick cache ==="
  local pc="$HOME/.cache/wallpaper-pick"
  if [[ -d "$pc" ]]; then
    local pc_tiles=0
    shopt -s nullglob
    for f in "$pc"/tiles/*.jpg; do
      [[ -f "$f" ]] && pc_tiles=$((pc_tiles+1))
    done
    shopt -u nullglob
    echo "  tiles: $pc_tiles"
    echo "  disk: $(du -sh "$pc" 2>/dev/null | cut -f1)"
  else
    echo "  no cache directory"
  fi
  echo
  echo "=== Processes ==="
  pgrep -af 'wallpaper-watcher|wallpaper-random|hyprpaper|rwpspread' 2>/dev/null | grep -v 'grep\|hermes' | sed 's/^/  /' || echo "  none"
}

case "${1:-}" in
  "")
    if [[ -L "$LINK" ]]; then
      readlink -f "$LINK"
      exit 0
    fi
    usage
    exit 1
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  --status)
    print_status
    exit 0
    ;;
  --refresh | -r)
    IMAGE="$(readlink -f "$LINK" 2>/dev/null || true)"
    [[ -n "$IMAGE" && -f "$IMAGE" ]] || {
      echo "wallpaper: no current background to refresh" >&2
      exit 1
    }
    # Try to find a pre-split tile sidecar for this image so we use
    # the fast IPC path instead of falling back to rwpspread.
    # Check omarchy-random-wallpaper cache first, then wallpaper-pick.
    omarchy_sc="$HOME/.cache/omarchy-random-wallpaper/.current.tiles"
    if [[ -s "$omarchy_sc" ]]; then
      omarchy_img="$(readlink -f "$HOME/.cache/omarchy-random-wallpaper/current".* 2>/dev/null | head -1 || true)"
      if [[ -n "$omarchy_img" && "$omarchy_img" == "$IMAGE" ]]; then
        TILES_SIDECAR="$omarchy_sc"
      fi
    fi
    if [[ -z "$TILES_SIDECAR" ]]; then
      pick_hash="$(sha256sum "$IMAGE" | cut -d' ' -f1)"
      pick_sc="$HOME/.cache/wallpaper-pick/.pick_${pick_hash}.tiles"
      [[ -s "$pick_sc" ]] && TILES_SIDECAR="$pick_sc"
    fi
    ;;
  --tiles)
    TILES_SIDECAR="${2:-}"
    IMAGE_ARG="${3:-}"
    [[ -n "$TILES_SIDECAR" && -f "$TILES_SIDECAR" ]] || {
      echo "wallpaper: --tiles requires an existing sidecar file" >&2
      exit 2
    }
    [[ -n "$IMAGE_ARG" ]] || {
      echo "wallpaper: --tiles requires an image path" >&2
      exit 2
    }
    IMAGE="$(realpath -- "$IMAGE_ARG")"
    [[ -f "$IMAGE" ]] || {
      echo "wallpaper: not a file: $IMAGE_ARG" >&2
      exit 1
    }
    mkdir -p "$(dirname "$LINK")"
    touch "$WATCHER_SKIP"
    ln -sfn "$IMAGE" "$LINK"
    ;;
  *)
    IMAGE="$(realpath -- "$1")"
    [[ -f "$IMAGE" ]] || {
      echo "wallpaper: not a file: $1" >&2
      exit 1
    }
    mkdir -p "$(dirname "$LINK")"
    touch "$WATCHER_SKIP"
    ln -sfn "$IMAGE" "$LINK"
    ;;
esac

if [[ -n "$TILES_SIDECAR" ]]; then
  command -v hyprctl >/dev/null 2>&1 || {
    echo "wallpaper: hyprctl not available" >&2
    exit 1
  }

  # Verify all tiles exist before applying. If any are missing (e.g.
  # deleted by gc_tiles or stale sidecar from a previous rwpspread run
  # with non-deterministic hashing), fall back to rwpspread so every
  # monitor gets the wallpaper instead of silently skipping monitors.
  missing_tiles=0
  while IFS= read -r tile || [[ -n "$tile" ]]; do
    [[ -n "$tile" ]] || continue
    [[ -f "$tile" ]] || { missing_tiles=1; break; }
  done <"$TILES_SIDECAR"

  if [[ "$missing_tiles" -ne 0 ]]; then
    echo "wallpaper: tiles missing from sidecar $TILES_SIDECAR, falling back to rwpspread" >&2
  else
    # Preload first (idempotent — no-op if already loaded), then set wallpaper.
    # hyprpaper <= 0.8.3 returns non-zero from `preload` even on success; the
    # image still loads, so we tolerate the exit code here.
    while IFS= read -r tile || [[ -n "$tile" ]]; do
      [[ -n "$tile" && -f "$tile" ]] || continue
      hyprctl hyprpaper preload "$tile" >/dev/null 2>&1 || true
    done <"$TILES_SIDECAR"

    while IFS= read -r tile || [[ -n "$tile" ]]; do
      [[ -n "$tile" && -f "$tile" ]] || continue
      base="${tile##*/}"
      stem="${base%.*}"
      if [[ "$stem" =~ ^rwps_(.+)_[a-f0-9]{64}$ ]]; then
        mon="${BASH_REMATCH[1]}"
      else
        echo "wallpaper: cannot parse monitor from tile: $base" >&2
        continue
      fi
      hyprctl hyprpaper wallpaper "$mon,$tile" >/dev/null
    done <"$TILES_SIDECAR"

    exit 0
  fi
  # Missing tiles: fall through to rwpspread fallback below.
fi

command -v rwpspread >/dev/null 2>&1 || {
  echo "wallpaper: rwpspread not installed (install from AUR: paru -S rwpspread)" >&2
  exit 1
}

# Timeout: rwpspread -b hyprpaper communicates with hyprpaper via a Unix
# socket. On hyprpaper 0.8.3 this IPC can deadlock — rwpspread waits for
# a response that never comes, hanging indefinitely and holding any
# parent flock. 30s is generous (normal apply is 2-3s) but ensures the
# process is killed and the lock is released.
exec timeout 30 rwpspread -b hyprpaper -i "$IMAGE"